# Grants Platform environment variables.
#
# Copy to `.env` and fill in real values. `.env` is gitignored; this file
# is committed so new contributors know which variables to set. Defaults
# shown here match `config.py` / `docker-compose.yml` -- everything except
# the API keys works out of the box for local dev.

# --- Flask core ---------------------------------------------------------
FLASK_SECRET_KEY=dev-secret-change-me
DATABASE_URL=sqlite:///grants.db
UPLOAD_FOLDER=./uploads/

# --- AI (Claude) --------------------------------------------------------
# Required for AI-assisted assessment and applicant pre-fill. Without
# this, the "AI assessment" action on the assessor workbench will flash
# an error and no scores will be generated. Get a key at
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- External validators -----------------------------------------------
# Flip to 0/false for offline / airgapped runs.
EXTERNAL_VALIDATORS_ENABLED=1
# Optional. When unset the Companies House validator reports itself as
# "skipped" and FindThatCharity is the sole fall-back.
COMPANIES_HOUSE_API_KEY=

# --- Outbound email (AI assessment notifications) ----------------------
NOTIFY_EMAIL=ross.mckelvie@fylde.gov.uk
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=grants-platform@noreply.local
